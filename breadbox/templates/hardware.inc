; Auto-generated by breadbox. Do not edit.
{% for device_id, device in devices.items() %}
{% if device.component_type == "core" %}

; --- Core ---
.setcpu "{{ device.cpu }}"
CPU_CLOCK = {{ device.clock_hz }}
{% elif device.component_type == "via_w65c22" and device.address is defined %}

; --- {{ device_id }} ---
{{ device_id }}_BASE = {{ device.address }}
{% for name, offset in device.registers %}
{{ device_id }}_{{ name }} = {{ device_id }}_BASE + {{ offset | hex }}
{% endfor %}
{% endif %}
{% endfor %}
