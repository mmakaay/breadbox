; Auto-generated by breadbox. Do not edit.
; GPIO pin: {{ device_id }} ({{ pin }} on {{ bus_device.id }}, port {{ port }})

{% set PORT_REG = bus_device.id ~ "_PORT" ~ port %}
{% set DDR_REG = bus_device.id ~ "_DDR" ~ port %}
{% set MASK = bitmask %}
{% set INV_MASK = 255 - bitmask %}
{% set BIDIR = (direction == "both") %}
{% if direction in ("out", "both") %}

; =========================================================================
; Set {{ device_id }} output high.
;
{% if BIDIR %}
; Switches DDR to output before writing.
;
{% endif %}
; Out:
;   A = clobbered

{% if exclusive_port %}
.macro {{ macro_prefix }}_on
{% if BIDIR %}
    lda #{{ MASK | hex }}
    sta {{ DDR_REG }}
    sta {{ PORT_REG }}
{% else %}
    lda #{{ MASK | hex }}
    sta {{ PORT_REG }}
{% endif %}
.endmacro
{% else %}
.macro {{ macro_prefix }}_on
{% if BIDIR %}
    lda {{ DDR_REG }}
    ora #{{ MASK | hex }}
    sta {{ DDR_REG }}
{% endif %}
    lda {{ PORT_REG }}
    ora #{{ MASK | hex }}
    sta {{ PORT_REG }}
.endmacro
{% endif %}

; =========================================================================
; Set {{ device_id }} output low.
;
{% if BIDIR %}
; Switches DDR to output before writing.
;
{% endif %}
; Out:
;   A = clobbered

{% if exclusive_port %}
.macro {{ macro_prefix }}_off
{% if BIDIR %}
    lda #{{ MASK | hex }}
    sta {{ DDR_REG }}
{% endif %}
    lda #$00
    sta {{ PORT_REG }}
.endmacro
{% else %}
.macro {{ macro_prefix }}_off
{% if BIDIR %}
    lda {{ DDR_REG }}
    ora #{{ MASK | hex }}
    sta {{ DDR_REG }}
{% endif %}
    lda {{ PORT_REG }}
    and #{{ INV_MASK | hex }}
    sta {{ PORT_REG }}
.endmacro
{% endif %}

; =========================================================================
; Toggle {{ device_id }} output.
;
{% if BIDIR %}
; Switches DDR to output before writing.
;
{% endif %}
; Out:
;   A = clobbered

.macro {{ macro_prefix }}_toggle
{% if BIDIR %}
{% if exclusive_port %}
    lda #{{ MASK | hex }}
    sta {{ DDR_REG }}
{% else %}
    lda {{ DDR_REG }}
    ora #{{ MASK | hex }}
    sta {{ DDR_REG }}
{% endif %}
{% endif %}
    lda {{ PORT_REG }}
    eor #{{ MASK | hex }}
    sta {{ PORT_REG }}
.endmacro
{% endif %}
{% if direction in ("in", "both") %}

; =========================================================================
; Read {{ device_id }} input state.
;
{% if BIDIR %}
; Switches DDR to input before reading.
;
{% endif %}
; Out:
;   A = pin state (bit {{ pin[-1] }}, masked)

.macro {{ macro_prefix }}_read
{% if BIDIR %}
{% if exclusive_port %}
    lda #$00
    sta {{ DDR_REG }}
{% else %}
    lda {{ DDR_REG }}
    and #{{ INV_MASK | hex }}
    sta {{ DDR_REG }}
{% endif %}
{% endif %}
    lda {{ PORT_REG }}
    and #{{ MASK | hex }}
.endmacro
{% endif %}

; =========================================================================
; Imports and public API scope
;
; Provides cross-file access to GPIO pin procedures.
; Usage: jsr {{ macro_prefix }}::turn_on, jsr {{ macro_prefix }}::read, etc.
; =========================================================================
.ifndef __{{ macro_prefix | upper }}_IMPL
{% if direction in ("out", "both") %}
.import __{{ macro_prefix }}_turn_on, __{{ macro_prefix }}_turn_off, __{{ macro_prefix }}_toggle
{% endif %}
{% if direction in ("in", "both") %}
.import __{{ macro_prefix }}_read
{% endif %}

.scope {{ macro_prefix }}
{% if direction in ("out", "both") %}
    turn_on  = __{{ macro_prefix }}_turn_on
    turn_off = __{{ macro_prefix }}_turn_off
    toggle   = __{{ macro_prefix }}_toggle
{% endif %}
{% if direction in ("in", "both") %}
    read     = __{{ macro_prefix }}_read
{% endif %}
.endscope
.endif  ; .ifndef __{{ macro_prefix | upper }}_IMPL
