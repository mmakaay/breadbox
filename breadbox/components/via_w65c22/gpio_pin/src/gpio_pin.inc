; Auto-generated by breadbox. Do not edit.
; GPIO pin: {{ device_id }} ({{ pin }} on {{ bus_device.id }}, port {{ port }})

{% set PORT_REG = bus_device.id ~ "_PORT" ~ port %}
{% set DDR_REG = bus_device.id ~ "_DDR" ~ port %}
{% set MASK = bitmask %}
{% set INV_MASK = 255 - bitmask %}
{% if direction in ("out", "both") %}

; =========================================================================
; Set {{ device_id }} output high.
;
; Out:
;   A = clobbered

{% if exclusive_port %}
.macro {{ device_id }}_on
    lda #{{ MASK | hex }}
    sta {{ PORT_REG }}
.endmacro
{% else %}
.macro {{ device_id }}_on
    lda {{ PORT_REG }}
    ora #{{ MASK | hex }}
    sta {{ PORT_REG }}
.endmacro
{% endif %}

; =========================================================================
; Set {{ device_id }} output low.
;
; Out:
;   A = clobbered

{% if exclusive_port %}
.macro {{ device_id }}_off
    lda #$00
    sta {{ PORT_REG }}
.endmacro
{% else %}
.macro {{ device_id }}_off
    lda {{ PORT_REG }}
    and #{{ INV_MASK | hex }}
    sta {{ PORT_REG }}
.endmacro
{% endif %}

; =========================================================================
; Toggle {{ device_id }} output.
;
; Out:
;   A = clobbered

.macro {{ device_id }}_toggle
    lda {{ PORT_REG }}
    eor #{{ MASK | hex }}
    sta {{ PORT_REG }}
.endmacro
{% endif %}
{% if direction in ("in", "both") %}

; =========================================================================
; Read {{ device_id }} input state.
;
; Out:
;   A = pin state (bit {{ pin[-1] }}, masked)

.macro {{ device_id }}_read
    lda {{ PORT_REG }}
    and #{{ MASK | hex }}
.endmacro
{% endif %}
