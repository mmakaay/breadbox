; Auto-generated by breadbox. Do not edit.
; GPIO group: {{ device_id }} (port {{ port }} on {{ bus_device.id }}, mask {{ bits | hex }})

{% set PORT_REG = bus_device.id ~ "_PORT" ~ port %}
{% set DDR_REG = bus_device.id ~ "_DDR" ~ port %}
{% set MASK = bits | int %}
{% set INV_MASK = 255 - MASK %}
{% if direction in ("out", "both") %}

; =========================================================================
; Write a value to {{ device_id }}.
;
; The value must use only the bits within the group mask ({{ bits | hex }}).
; Bits outside the mask are ignored{% if not exclusive_port %} and preserved{% endif %}.
;
; In:
;   value = immediate byte value to write (pre-masked to {{ bits | hex }})
; Out:
;   A = clobbered

{% if exclusive_port %}
.macro {{ device_id }}_write value
    lda #value
    sta {{ PORT_REG }}
.endmacro
{% else %}
.macro {{ device_id }}_write value
    lda {{ PORT_REG }}
    and #{{ INV_MASK | hex }}
    ora #value
    sta {{ PORT_REG }}
.endmacro
{% endif %}

; =========================================================================
; Set all {{ device_id }} outputs high.
;
; Out:
;   A = clobbered

{% if exclusive_port %}
.macro {{ device_id }}_on
    lda #{{ MASK | hex }}
    sta {{ PORT_REG }}
.endmacro
{% else %}
.macro {{ device_id }}_on
    lda {{ PORT_REG }}
    ora #{{ MASK | hex }}
    sta {{ PORT_REG }}
.endmacro
{% endif %}

; =========================================================================
; Set all {{ device_id }} outputs low.
;
; Out:
;   A = clobbered

{% if exclusive_port %}
.macro {{ device_id }}_off
    lda #$00
    sta {{ PORT_REG }}
.endmacro
{% else %}
.macro {{ device_id }}_off
    lda {{ PORT_REG }}
    and #{{ INV_MASK | hex }}
    sta {{ PORT_REG }}
.endmacro
{% endif %}

; =========================================================================
; Toggle all {{ device_id }} outputs.
;
; Out:
;   A = clobbered

.macro {{ device_id }}_toggle
    lda {{ PORT_REG }}
    eor #{{ MASK | hex }}
    sta {{ PORT_REG }}
.endmacro
{% endif %}
{% if direction in ("in", "both") %}

; =========================================================================
; Read {{ device_id }} input state.
;
; Out:
;   A = group state (masked to {{ bits | hex }})

.macro {{ device_id }}_read
    lda {{ PORT_REG }}
    and #{{ MASK | hex }}
.endmacro
{% endif %}
