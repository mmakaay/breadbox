; Auto-generated by breadbox. Do not edit.
; HD44780 LCD: {{ device_id }} ({{ mode }} mode)
;
; Control pins: RS={{ pin_rs.pin }}, RWB={{ pin_rwb.pin }}, EN={{ pin_en.pin }}
; Data bus: port {{ data.port }} on {{ data.bus_device.id }}, mask {{ data.bits | hex }}

{% set P = macro_prefix %}

; =========================================================================
; Imports
; =========================================================================

.importzp __{{ P }}_byte, __{{ P }}_ptr
.import   __{{ P }}_init, __{{ P }}_write_cmnd, __{{ P }}_write
.import   __{{ P }}_clr, __{{ P }}_home, __{{ P }}_print

; =========================================================================
; HD44780 command constants
; =========================================================================

{{ P }}_CMD_CLEAR      = $01  ; Clear display, set DDRAM address to 0
{{ P }}_CMD_HOME       = $02  ; Return cursor to home position
{{ P }}_CMD_ENTRYMODE  = $06  ; Increment cursor, no display shift
{{ P }}_CMD_DISPLAY_ON = $0C  ; Display on, cursor off, blink off
{% if mode == "4bit" %}
{{ P }}_CMD_FUNCSET    = $28  ; 4-bit mode, 2 lines, 5x8 font
{% else %}
{{ P }}_CMD_FUNCSET    = $38  ; 8-bit mode, 2 lines, 5x8 font
{% endif %}
{{ P }}_CMD_SETDDRAM   = $80  ; Set DDRAM address (OR with address)
{{ P }}_CMD_SETCGRAM   = $40  ; Set CGRAM address (OR with address)

{{ P }}_BUSY_FLAG      = $80  ; Busy flag mask (bit 7)

{{ P }}_LINE1          = $00  ; DDRAM address for line 1
{{ P }}_LINE2          = $40  ; DDRAM address for line 2

; =========================================================================
; Public API scope
;
; Provides cross-file access to LCD procedures and zero page variables.
; Usage: jsr {{ P }}::print, sta {{ P }}::byte, etc.
; =========================================================================

.scope {{ P }}
    byte       = __{{ P }}_byte
    ptr        = __{{ P }}_ptr
    init       = __{{ P }}_init
    write_cmnd = __{{ P }}_write_cmnd
    write      = __{{ P }}_write
    clr        = __{{ P }}_clr
    home       = __{{ P }}_home
    print      = __{{ P }}_print
.endscope

; =========================================================================
; Set cursor position to the beginning of a display line.
;
; In:
;   line = line address constant ({{ P }}_LINE1 or {{ P }}_LINE2)
; Out:
;   A = clobbered

.macro {{ P }}_goto line
    lda #({{ P }}_CMD_SETDDRAM | line)
    sta {{ P }}::byte
    jsr {{ P }}::write_cmnd
.endmacro

; =========================================================================
; Write a character to the display at the current cursor position.
;
; In:
;   char = immediate character byte to write
; Out:
;   A = clobbered

.macro {{ P }}_putc char
    lda #char
    sta {{ P }}::byte
    jsr {{ P }}::write
.endmacro
